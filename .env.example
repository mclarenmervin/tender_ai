DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/tender_ai
SECRET_KEY=replace_with_a_long_random_secret

# Optional AI scoring
USE_OPENAI_SCORING=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional alert thresholds
HIGH_PRIORITY_SCORE=70
DEADLINE_ALERT_DAYS=10

# Optional Telegram alerts
TELEGRAM_BOT_TOKEN=

# Optional email alerts
ADMIN_EMAIL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true

# Optional scraping behavior
SCRAPE_PDF_VALUES=false
MANUAL_SCRAPE_USER_ID=
MANUAL_SCRAPE_TRIGGER=manual

# Optional GeM scraper proxy/static egress
GEM_PROXY_SERVER=
GEM_PROXY_USERNAME=
GEM_PROXY_PASSWORD=
